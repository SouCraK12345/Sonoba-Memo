{
  "manifest_version": 3,
  "name": "その場メモ",
  "version": "1.0.0",
  "description": "作業中にサッとメモ。chrome.storage.sync で端末をまたいで同期。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "その場メモ",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
